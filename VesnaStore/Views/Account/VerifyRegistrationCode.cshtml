<div class="auth-page">
    <div class="auth-card">
        <h2>Подтвердите почту</h2>
        <p style="font-size:0.85rem; color:#666; text-align:center; margin-bottom:20px;">
            Мы отправили код на ваш Email. Введите его, чтобы завершить регистрацию.
        </p>

        @if (TempData["Error"] != null)
        {
            <div style="color:red; font-size:0.85rem; margin-bottom:15px; text-align:center;">@TempData["Error"]</div>
        }

        <form asp-action="VerifyRegistrationCode" method="post">
            @Html.AntiForgeryToken()
            <div class="auth-form-group">
                <input name="code" type="text" class="auth-input" placeholder="000000" maxlength="6" required style="text-align:center; letter-spacing: 5px; font-size: 1.2rem;" />
            </div>
            <button type="submit" class="btn-auth">Завершить регистрацию</button>
        </form>
    </div>
</div>