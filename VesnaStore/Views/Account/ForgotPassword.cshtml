@{
    ViewData["Title"] = "Восстановление пароля";
}
<div class="auth-page">
    <div class="auth-card">
        <h2>Восстановление</h2>
        <p style="font-size:0.85rem; color:#666; text-align:center; margin-bottom:20px;">Укажите Email вашего аккаунта, и мы вышлем код для сброса пароля.</p>

        @if (TempData["Error"] != null)
        {
            <div style="color:red; font-size:0.85rem; margin-bottom:15px; text-align:center;">@TempData["Error"]</div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="auth-form-group">
                <label>Ваш Email</label>
                <input name="email" type="email" class="auth-input" required />
            </div>
            <button type="submit" class="btn-auth">Получить код</button>
        </form>
        <div class="auth-footer-link">
            <a asp-action="Login">Вернуться к входу</a>
        </div>
    </div>
</div>