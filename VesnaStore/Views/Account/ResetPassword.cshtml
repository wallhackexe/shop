@{
    ViewData["Title"] = "Новый пароль";
}
<div class="auth-page">
    <div class="auth-card">
        <h2>Новый пароль</h2>
        <p style="font-size:0.85rem; color:#666; text-align:center; margin-bottom:20px;">Код подтвержден. Придумайте новый надежный пароль.</p>

        @if (TempData["Error"] != null)
        {
            <div style="color:red; font-size:0.85rem; margin-bottom:15px; text-align:center;">@TempData["Error"]</div>
        }

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="auth-form-group">
                <label>Новый пароль</label>
                <input name="newPassword" type="password" class="auth-input" required />
            </div>
            <button type="submit" class="btn-auth">Обновить пароль</button>
        </form>
    </div>
</div>