@{
    ViewData["Title"] = "Подтверждение входа";
}

<div class="auth-page">
    <div class="auth-card">
        <h2>Подтверждение</h2>
        <p style="font-size:0.85rem; color:#666; text-align:center; margin-bottom:20px;">
            На вашу почту отправлен одноразовый 6-значный код подтверждения.
        </p>

        @if (TempData["Error"] != null)
        {
            <div style="color:red; font-size:0.85rem; margin-bottom:15px; text-align:center;">@TempData["Error"]</div>
        }

        <form asp-action="VerifyLoginCode" method="post">
            @Html.AntiForgeryToken()

            <div class="auth-form-group">
                <label>Код из письма</label>
                <input name="code" type="text" class="auth-input" placeholder="000000" maxlength="6" required
                       style="text-align:center; letter-spacing: 5px; font-size: 1.2rem;" />
            </div>

            <div style="display: flex; align-items: flex-start; gap: 10px; margin-bottom: 25px; text-align: left; padding: 0 5px;">
                <input type="checkbox" id="rememberDevice" name="rememberDevice" value="true" checked
                       style="margin-top: 4px; cursor: pointer; accent-color: #DCAEAE;" />
                <label for="rememberDevice" style="font-size: 0.75rem; color: #888; line-height: 1.4; cursor: pointer; font-weight: 500; text-transform: none; letter-spacing: 0;">
                    Запомнить это устройство <br>
                    <span style="font-size: 0.65rem; color: #aaa;">(не запрашивать код в течение 30 дней)</span>
                </label>
            </div>

            <button type="submit" class="btn-auth">Подтвердить</button>
        </form>

        <div style="margin-top: 20px;">
            <a href="/Account/Login" style="font-size: 0.75rem; color: #DCAEAE; text-decoration: none; font-weight: 600;">Вернуться назад</a>
        </div>
    </div>
</div>