@model IEnumerable<VesnaStore.Models.Product>
@{
    ViewData["Title"] = "Главная — VESNA";
    Layout = "_Layout";

    var userFavs = ViewBag.UserFavorites as List<int> ?? new List<int>();
}

<main class="main-content">
    <section class="hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <h1 class="hero-title">Твоя новая весна</h1>
            <p class="hero-subtitle">Коллекция, вдохновленная нежностью и легкостью</p>
            <a href="/Home/Catalog" class="btn-main">Каталог</a>
        </div>
    </section>

    <section class="container py-100" id="catalog">
        <div class="section-header" style="text-align: center; margin-bottom: 50px;">
            <h2 class="title-main" style="font-family: 'Playfair Display'; font-size: 3rem; margin-bottom: 10px;">Весенние новинки</h2>
            <div style="width: 50px; height: 2px; background: #DCAEAE; margin: 0 auto 15px;"></div>
            <div class="subtitle-main" style="color: #888;">Эксклюзивные модели 2026 года</div>
        </div>

        <div class="product-grid" id="product-container">
            @if (Model != null && Model.Any(p => p.IsPublished && p.IsNew))
            {
                @foreach (var item in Model.Where(p => p.IsPublished && p.IsNew))
                {
                    bool isLiked = userFavs.Contains(item.ProductID);

                    <div class="product-card"
                         data-id="@item.ProductID"
                         data-name="@item.Title"
                         data-price="@item.Price"
                         data-cat="@(item.Category?.Name ?? "Без категории")"
                         data-desc="@item.Description"
                         data-additional="@item.AdditionalImages"
                         data-sxa="@(item.StartX_A ?? 0)" data-sya="@(item.StartY_A ?? 0)"
                         data-exa="@(item.EndX_A ?? 0)" data-eya="@(item.EndY_A ?? 0)"
                         data-mxa="@(item.TextX_A ?? 0)" data-mya="@(item.TextY_A ?? 0)" data-vala="@item.SizeValueA"
                         data-sxb="@(item.StartX_B ?? 0)" data-syb="@(item.StartY_B ?? 0)"
                         data-exb="@(item.EndX_B ?? 0)" data-eyb="@(item.EndY_B ?? 0)"
                         data-mxb="@(item.TextX_B ?? 0)" data-myb="@(item.TextY_B ?? 0)" data-valb="@item.SizeValueB"
                         data-sxc="@(item.StartX_C ?? 0)" data-syc="@(item.StartY_C ?? 0)"
                         data-exc="@(item.EndX_C ?? 0)" data-eyc="@(item.EndY_C ?? 0)"
                         data-mxc="@(item.TextX_C ?? 0)" data-myc="@(item.TextY_C ?? 0)" data-valc="@item.SizeValueC">

                        @* КНОПКА ИЗБРАННОГО *@
                        <button class="wishlist-heart @(isLiked ? "active" : "")"
                                onclick="toggleLike(@item.ProductID, this)"
                                style="position: absolute; top: 15px; right: 15px; z-index: 5; background: none; border: none; cursor: pointer;">
                            <i class="@(isLiked ? "fa-solid" : "fa-regular") fa-heart"></i>
                        </button>

                        <div class="product-image-box" style="cursor: pointer;">
                            <img src="@item.ImageURL" alt="@item.Title">
                        </div>

                        <div class="product-details">
                            <span class="product-category">
                                @(item.Category?.Name?.ToUpper() ?? "БЕЗ КАТЕГОРИИ")
                            </span>
                            <h3 class="product-title" style="cursor: pointer;">@item.Title</h3>

                            @* ДИНАМИЧЕСКИЙ РЕЙТИНГ ИЗ БД *@
                            <div class="product-rating">
                                @for (int i = 0; i < 5; ++i)
                                {
                                    <i class="fa-solid fa-star"></i>
                                }
                                <span class="rating-value">
                                    @{
                                        var approvedReviews = item.Reviews?.Where(r => r.IsApproved).ToList();
                                        int count = approvedReviews?.Count ?? 0;
                                        double avgRating = count > 0 ? approvedReviews.Average(r => r.Rating) : 5.0;
                                    }
                                    @avgRating.ToString("F1")
                                    @if (count > 0)
                                    {
                                        <span class="reviews-num">(@count)</span>
                                    }
                                </span>
                            </div>

                            <div class="product-price-row">
                                <span class="price">@item.Price.ToString("N0") ₽</span>
                                <button class="btn-add-cart" data-id="@item.ProductID">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center; width:100%; padding: 50px;">
                    <i class="fa-solid fa-hourglass-start" style="font-size: 3rem; color: #eee; margin-bottom: 20px;"></i>
                    <p style="color: #999;">Товары скоро появятся в продаже...</p>
                </div>
            }
        </div>
    </section>

    <section class="container py-100" id="about" style="border-top: 1px solid #f4f4f4; background: #fafafa; border-radius: 50px 50px 0 0;">
        <div class="about-grid" style="align-items: center;">
            <div class="about-image">
                <img src="https://i.ibb.co/zL8WYDs/MG-1852.jpg"
                     style="width: 100%; border-radius: 30px; box-shadow: 0 30px 60px rgba(0,0,0,0.12);" alt="О магазине">
            </div>
            <div class="about-text">
                <h2 style="font-family: 'Playfair Display'; font-size: 3rem; margin-bottom: 25px; color: #222;">Философия ВЕСНЫ</h2>
                <p style="color: #555; line-height: 1.8; margin-bottom: 20px; font-size: 1.1rem;">
                    Мы верим, что одежда — это не просто ткань, а отражение вашего внутреннего состояния. Наш бренд создает образы для тех, кто ценит эстетику минимализма и безупречное качество.
                </p>
                <p style="color: #555; line-height: 1.8; font-size: 1.1rem;">
                    Каждая коллекция создается ограниченным тиражом из натуральных итальянских тканей, чтобы вы чувствовали свою уникальность в любой ситуации.
                </p>
            </div>
        </div>
    </section>
</main>

<div class="modal-overlay" id="v2-modal">
    <div class="modal-window">
        <div class="modal-content-grid" style="display: grid; grid-template-columns: 1.1fr 0.9fr; flex: 1; overflow-y: auto;">
            <div class="modal-slider-side" style="background: #f4f4f4; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; min-height: 450px;">
                <div id="v2-slides" style="display: flex; transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); width: 100%; height: 100%;"></div>
                <button id="v2-prev" style="position: absolute; left: 20px; background: white; border: none; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; box-shadow: 0 5px 15px rgba(0,0,0,0.1); display: none; z-index: 10;">&larr;</button>
                <button id="v2-next" style="position: absolute; right: 20px; background: white; border: none; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; box-shadow: 0 5px 15px rgba(0,0,0,0.1); display: none; z-index: 10;">&rarr;</button>
                <div id="v2-dots" style="position: absolute; bottom: 20px; display: flex; gap: 8px; z-index: 10;"></div>
            </div>
            <div class="modal-info-side" style="padding: 40px; display: flex; flex-direction: column; background: white;">
                <span id="v2-cat" style="background: #fdf2f2; color: #DCAEAE; padding: 6px 16px; border-radius: 20px; font-size: 0.75rem; letter-spacing: 1px; width: fit-content; font-weight: 700;"></span>
                <h2 id="v2-title" style="font-family: 'Playfair Display'; font-size: 2.2rem; margin: 20px 0 10px; color: #222;"></h2>
                <p id="v2-price" style="font-size: 1.6rem; color: #111; margin-bottom: 30px; font-weight: 700;"></p>
                <div style="margin-bottom: 25px; flex-grow: 1;">
                    <p style="font-size: 0.7rem; color: #aaa; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 8px; font-weight: 700;">Описание</p>
                    <p id="v2-desc" style="color: #666; line-height: 1.6; font-size: 0.95rem; margin: 0;"></p>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px;">
                    <button class="btn-main modal-add-to-cart-btn" style="padding: 18px; border-radius: 15px; background: #111; color: #fff; border: none; cursor: pointer; font-weight: 600; font-size: 0.85rem;">В КОРЗИНУ</button>
                    <a id="v2-link" href="#" style="text-decoration: none; padding: 18px; border-radius: 15px; background: #fff; color: #111; border: 1px solid #eee; text-align: center; font-weight: 600; font-size: 0.85rem; transition: 0.3s;">ПОДРОБНЕЕ</a>
                </div>
            </div>
        </div>
    </div>
</div>
</div>