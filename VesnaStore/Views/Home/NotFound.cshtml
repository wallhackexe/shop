@{
    ViewData["Title"] = "Страница не найдена";
    Layout = "_Layout";
}

<div class="container cart-page-wrapper" style="text-align: center; padding-top: 120px; padding-bottom: 120px; min-height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center;">

    <h1 style="font-family: 'Playfair Display'; font-size: 12rem; color: #fdf2f2; margin: 0; line-height: 0.8; text-shadow: 0 10px 30px rgba(220, 174, 174, 0.15);">404</h1>

    <h2 style="font-family: 'Playfair Display'; font-size: 2.5rem; margin-bottom: 20px; color: #222; position: relative; top: -20px;">Упс! Страница потерялась</h2>

    <p style="color: #888; margin-bottom: 40px; font-size: 1.1rem; max-width: 500px; line-height: 1.6;">
        Кажется, вы перешли по неверной ссылке или эта модель уже распродана. Но не переживайте, у нас еще много красивых вещей для вашей весны.
    </p>

    <a href="/Home/Catalog" class="btn-main" style="border-radius: 12px; padding: 18px 45px; box-shadow: 0 10px 20px rgba(0,0,0,0.05);">ВЕРНУТЬСЯ К НОВИНКАМ</a>

</div>