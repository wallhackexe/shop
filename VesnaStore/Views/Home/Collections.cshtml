@{
    ViewData["Title"] = "Коллекции";
    Layout = "_Layout";
}

<div class="container cart-page-wrapper" style="padding-top: 140px; padding-bottom: 100px;">
    <div class="section-header" style="text-align: center; margin-bottom: 60px;">
        <h1 style="font-family: 'Playfair Display'; font-size: 3.5rem; margin-bottom: 15px;">Наши коллекции</h1>
        <div style="width: 60px; height: 3px; background: #DCAEAE; margin: 0 auto;"></div>
    </div>

    <div class="collections-grid">
        @* Карточка 1: ВЕСНА 2026 *@
        <div class="collection-card">
            <img src="https://i.ibb.co/5XcKgW9Y/photo-1469334031218-e382a71b716b.avif" alt="Весна 2026">
            <div class="collection-overlay">
                <h2 style="font-family: 'Playfair Display'; font-size: 2.5rem; margin-bottom: 10px;">ВЕСНА 2026</h2>
                <p style="opacity: 0.9; margin-bottom: 20px; font-weight: 300;">Шелковые платья и легкие тренчи для вдохновения</p>
                <a href="/Home/Catalog" style="color: white; text-decoration: none; font-weight: 600; border-bottom: 1px solid white; width: fit-content; padding-bottom: 5px;">СМОТРЕТЬ КАТАЛОГ</a>
            </div>
        </div>

        @* Карточка 2: БАЗОВАЯ ЛИНИЯ *@
        <div class="collection-card">
            <img src="https://i.ibb.co/21QBvQW6/photo-1490481651871-ab68de25d43d-1.avif" alt="Basic Line">
            <div class="collection-overlay">
                <h2 style="font-family: 'Playfair Display'; font-size: 2.5rem; margin-bottom: 10px;">БАЗОВАЯ ЛИНИЯ</h2>
                <p style="opacity: 0.9; margin-bottom: 20px; font-weight: 300;">Хлопок и лен — основа вашего комфорта</p>
                <a href="/Home/Catalog" style="color: white; text-decoration: none; font-weight: 600; border-bottom: 1px solid white; width: fit-content; padding-bottom: 5px;">СМОТРЕТЬ КАТАЛОГ</a>
            </div>
        </div>

        </div>
    </div>
</div>