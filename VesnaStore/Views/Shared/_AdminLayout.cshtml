<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Панель управления</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin-style.css" asp-append-version="true" />
    <style>
            /* Принудительная чистота для админского сайдбара */
            .admin-nav-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 15px 20px;
                color: #a0a0a0;
                text-decoration: none;
                font-size: 0.85rem;
                font-weight: 600;
                transition: 0.3s;
                border-radius: 10px;
            }

                .admin-nav-link:hover {
                    background: rgba(255,255,255,0.05);
                    color: #fff;
                }

                .admin-nav-link i {
                    width: 20px;
                    font-size: 0.9rem;
                }

            .admin-logo {
                display: block;
                font-family: 'Playfair Display';
                font-size: 1.5rem;
                color: #fff;
                text-decoration: none;
                padding: 20px;
                margin-bottom: 20px;
            }

            .admin-section-title {
                font-size: 0.65rem;
                color: #666;
                text-transform: uppercase;
                letter-spacing: 1px;
                padding: 20px 20px 10px;
                font-weight: 800;
            }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="overlay"></div>

    <header class="mobile-header">
        <button class="burger-btn" id="burger"><i class="fa-solid fa-bars"></i></button>
        <div style="font-weight: 700; letter-spacing: 1px;">ВЕСНА АДМИН</div>
        <div style="width: 24px;"></div>
    </header>

    <nav class="admin-sidebar" id="sidebar">
        <a href="/Admin/Index" class="admin-logo">ВЕСНА</a>

        <div class="admin-section-title">Магазин</div>
        <a href="/Admin/Index" class="admin-nav-link"><i class="fa-solid fa-store"></i> Товары</a>
        <a href="/Admin/Orders" class="admin-nav-link"><i class="fa-solid fa-cart-shopping"></i> Заказы</a>
        <a href="/Admin/Categories" class="admin-nav-link"><i class="fa-solid fa-list"></i> Категории</a>
        <a href="/Admin/Inventory" class="admin-nav-link"><i class="fa-solid fa-boxes-stacked"></i> Склад</a>
        <a href="/Admin/Media" class="admin-nav-link"><i class="fa-regular fa-images"></i> Медиатека</a>

        <div class="admin-section-title" style="margin-top: 10px;">CRM и Маркетинг</div>
        <a href="/Admin/Reviews" class="admin-nav-link"><i class="fa-solid fa-comments"></i> Отзывы</a>
        <a href="/Admin/MailingPanel" class="admin-nav-link"><i class="fa-regular fa-paper-plane"></i> Рассылка</a>
        <a href="/Admin/PromoCodes" class="admin-nav-link"><i class="fa-solid fa-ticket"></i> Промокоды</a>

        <a href="/" class="admin-nav-link" style="margin-top: auto; border-top: 1px solid #333; padding-top: 20px; opacity: 0.7;">
            <i class="fa-solid fa-arrow-left"></i> На сайт
        </a>
    </nav>

    <main class="admin-main">
        @RenderBody()
    </main>

    <script src="~/js/script.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
        var errorMsg = @Json.Serialize(TempData["Error"]);
        var successMsg = @Json.Serialize(TempData["Success"]);
        if (errorMsg) Swal.fire({ icon: 'error', title: 'Ошибка!', text: errorMsg, confirmButtonColor: '#111' });
        if (successMsg) Swal.fire({ icon: 'success', title: 'Готово', text: successMsg, timer: 2000, showConfirmButton: false });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>