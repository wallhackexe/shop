@using VesnaStore.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext _db

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — ВЕСНА</title>
    @Html.AntiForgeryToken()

    <link rel="stylesheet" href="~/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <script>
            window.isAuthenticated = @(User.Identity.IsAuthenticated.ToString().ToLower());
    </script>

    <style>
            header, .header-nav, .header-nav a {
                font-family: 'Montserrat', sans-serif !important;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 1px;
                font-size: 0.85rem;
            }

            .header-logo {
                font-family: 'Playfair Display', serif !important;
                font-weight: 700;
                text-transform: none;
            }

            @@media (max-width: 768px) {
                .footer-socials {
                    justify-content: center !important;
                }

                .footer-bottom-bar {
                    flex-direction: column !important;
                    text-align: center !important;
                    gap: 15px !important;
                }

                    .footer-bottom-bar > div {
                        justify-content: center !important;
                        flex-wrap: wrap;
                        gap: 10px !important;
                    }

                .footer-grid p, .footer-grid div {
                    text-align: center !important;
                    margin-left: auto;
                    margin-right: auto;
                }
            }
    </style>
</head>
<body class="site-wrapper">

    <header class="navbar">
        <div class="container nav-container">
            <div class="nav-left">
                <button class="mobile-menu-btn" id="menu-open-btn"><i class="fa-solid fa-bars-staggered"></i></button>

                <nav class="desktop-menu">
                    <a asp-controller="Home" asp-action="Catalog">Каталог</a>
                    <a asp-controller="Home" asp-action="Collections">КОЛЛЕКЦИИ</a>
                    <a href="/Home/Index#about">О НАС</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" style="color: #DCAEAE; font-weight: 600;">АДМИНКА</a>
                    }
                </nav>
            </div>

            <a href="/" class="logo">ВЕСНА</a>

            <div class="nav-right">
                <a href="/Cart/Index" class="nav-icon-item cart-trigger" id="cart-btn">
                    <i class="fa-solid fa-bag-shopping"></i>
                    <span class="cart-badge" id="cart-count">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                            int count = 0;
                            if (!string.IsNullOrEmpty(userIdClaim))
                            {
                                int uId = int.Parse(userIdClaim);
                                count = _db.CartItems.Where(c => c.UserID == uId).Sum(c => (int?)c.Quantity) ?? 0;
                            }
                            @count
                        }
                        else
                        {
                            @:0
                        }
                    </span>
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="User" asp-action="Profile" class="nav-icon-item" title="Личный кабинет" style="margin-left: 15px; color: var(--dark); text-decoration: none;">
                        <i class="fa-regular fa-user" style="font-size: 1.2rem;"></i>
                    </a>
                    <a href="/Account/Logout" class="btn-login-nav" style="margin-left: 15px;">ВЫЙТИ</a>
                }
                else
                {
                    <a href="/Account/Login?ReturnUrl=@Context.Request.Path" class="btn-login-nav">ВОЙТИ</a>
                }
            </div>
        </div>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer" style="background: #111; color: white; padding: 70px 0 25px; flex: 0 0 auto;">
        <div class="container">
            <div class="footer-grid" style="gap: 40px; border-bottom: 1px solid #222; padding-bottom: 40px;">
                <div>
                    <a href="/" style="font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; letter-spacing: 5px; text-decoration: none; color: white; text-transform: uppercase; display: block; margin-bottom: 20px;">ВЕСНА</a>
                    <p style="color: #888; font-size: 0.85rem; line-height: 1.6; margin-bottom: 20px; max-width: 300px;">
                        Создаем образы для тех, кто ценит эстетику минимализма и безупречное качество.
                    </p>
                    <div style="color: #666; font-size: 0.75rem; line-height: 1.5;">
                        <p style="margin: 0;">ИП Кокорина С.В. </p>
                        <p style="margin: 0;">ИНН: 290400343260</p>
                        <p style="margin: 0;">ОГРНИП: 304290434500141</p>
                        <p style="margin: 0;">Юр. адрес: Архангельская область, Котласский район, город Котлас</p>
                    </div>
                </div>

                <div class="footer-links">
                    <h4 style="font-family: 'Playfair Display'; font-size: 1.2rem; margin-bottom: 20px; color: #fff;">Покупателям</h4>
                    <a href="/Home/Catalog" style="display: block; color: #888; text-decoration: none; margin-bottom: 12px; font-size: 0.9rem; transition: 0.3s;">Каталог товаров</a>
                    <a href="/Home/Collections" style="display: block; color: #888; text-decoration: none; margin-bottom: 12px; font-size: 0.9rem; transition: 0.3s;">Коллекции</a>
                    <a href="/Home/Delivery" style="display: block; color: #888; text-decoration: none; margin-bottom: 12px; font-size: 0.9rem; transition: 0.3s;">Оплата и доставка</a>
                    <a href="/Home/Returns" style="display: block; color: #888; text-decoration: none; margin-bottom: 12px; font-size: 0.9rem; transition: 0.3s;">Обмен и возврат</a>
                </div>

                <div class="footer-links">
                    <h4 style="font-family: 'Playfair Display'; font-size: 1.2rem; margin-bottom: 20px; color: #fff;">Связаться с нами</h4>
                    <a href="tel:+79532645410" style="display: block; color: #888; text-decoration: none; margin-bottom: 12px; font-size: 0.9rem; transition: 0.3s;"><i class="fa-solid fa-phone" style="width: 20px;"></i> +7 (953) 264-54-10</a>
                    <a href="mailto:fogetw@gmail.com" style="display: block; color: #888; text-decoration: none; margin-bottom: 12px; font-size: 0.9rem; transition: 0.3s;"><i class="fa-regular fa-envelope" style="width: 20px;"></i> fogetw@gmail.com</a>
                    <div class="footer-socials" style="display: flex; gap: 15px; margin-top: 20px;">
                        <a href="#" style="color: #fff; font-size: 1.2rem; transition: 0.3s;"><i class="fa-brands fa-telegram"></i></a>
                        <a href="#" style="color: #fff; font-size: 1.2rem; transition: 0.3s;"><i class="fa-brands fa-vk"></i></a>
                    </div>
                </div>
            </div>

            <div class="footer-bottom-bar" style="display: flex; justify-content: space-between; align-items: center; padding-top: 25px; flex-wrap: wrap; gap: 15px;">
                <p style="color: #555; font-size: 0.8rem; margin: 0;">&copy; 2026 Магазин ВЕСНА. Все права защищены.</p>
                <div style="display: flex; gap: 20px;">
                    <a href="/Home/Privacy" style="color: #555; text-decoration: none; font-size: 0.8rem; transition: 0.3s;">Политика конфиденциальности</a>
                    <a href="/Home/Cookies" style="color: #555; text-decoration: none; font-size: 0.8rem; transition: 0.3s;">Настройки Cookie</a>
                </div>
            </div>
        </div>
    </footer>

    @* Мобильное меню *@
    <div class="mobile-menu-overlay" id="mobile-menu">
        <div class="mobile-menu-content">
            <button class="menu-close-btn" id="menu-close-btn">&times;</button>
            <nav class="mobile-nav-links">
                <a href="/Home/Catalog">КАТАЛОГ</a>
                <a href="/Home/Collections">КОЛЛЕКЦИИ</a>
                <a href="/Home/About">О НАС</a>
                <a href="/User/Profile">ПРОФИЛЬ</a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Index" style="color: #DCAEAE;">АДМИНКА</a>
                }
            </nav>
        </div>
    </div>

    <script src="~/js/script.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
        var errorMsg = @Json.Serialize(TempData["Error"]);
        var successMsg = @Json.Serialize(TempData["Success"]);
        if (errorMsg) {
        Swal.fire({ icon: 'error', title: 'Ой!', text: errorMsg, confirmButtonColor: '#111', confirmButtonText: 'Понятно' });
        }
        if (successMsg) {
        Swal.fire({ icon: 'success', title: 'Готово', text: successMsg, timer: 2000, showConfirmButton: false });
        }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div id="cookie-consent-banner" style="display: none; position: fixed; bottom: 0; left: 0; width: 100%; background: rgba(34, 34, 34, 0.95); backdrop-filter: blur(10px); color: white; z-index: 9999; padding: 20px 20px; box-shadow: 0 -10px 30px rgba(0,0,0,0.1); box-sizing: border-box;">
        <div class="container" style="display: flex; flex-direction: column; gap: 15px; align-items: center; text-align: center;">
            <p style="font-size: 0.75rem; line-height: 1.6; color: #ccc; margin: 0; max-width: 1000px;">
                Пользуясь сайтом магазина «Весна» Вы даете согласие на обработку файлов cookies...
                <a href="/Home/Cookies" style="color: #DCAEAE; text-decoration: underline;">Подробнее...</a>
            </p>
            <button id="accept-cookies-btn" style="background: #DCAEAE; color: #222; border: none; padding: 12px 30px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.3s; font-size: 0.8rem; letter-spacing: 1px;">
                СОГЛАШАЮСЬ
            </button>
        </div>
    </div>
</body>
</html>